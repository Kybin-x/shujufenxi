<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>3.2.4 数据透视表 · 任务书</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: "Microsoft YaHei", "PingFang SC", sans-serif;
      background: #f4f6f9;
      color: #2c3e50;
      line-height: 1.7;
    }

    /* ===== Banner ===== */
    .banner {
      background: linear-gradient(135deg, #558b2f 0%, #33691e 100%);
      color: #fff;
      padding: 36px 48px 28px;
    }
    .banner .course-tag {
      font-size: 12px;
      letter-spacing: 2px;
      opacity: .75;
      margin-bottom: 8px;
    }
    .banner h1 { font-size: 26px; font-weight: 700; margin-bottom: 6px; }
    .banner .subtitle { font-size: 14px; opacity: .85; }
    .banner .meta {
      margin-top: 18px;
      display: flex;
      gap: 24px;
      flex-wrap: wrap;
      font-size: 13px;
      opacity: .9;
    }

    /* ===== 主体 ===== */
    .container {
      max-width: 980px;
      margin: 32px auto;
      padding: 0 24px 60px;
    }

    /* ===== 情景卡片 ===== */
    .scenario-card {
      background: #fff;
      border-left: 5px solid #558b2f;
      border-radius: 8px;
      padding: 20px 24px;
      margin-bottom: 28px;
      box-shadow: 0 2px 8px rgba(0,0,0,.07);
    }
    .scenario-card h2 { font-size: 15px; color: #558b2f; margin-bottom: 8px; }
    .scenario-card p { font-size: 14px; }

    /* ===== 知识点速览 ===== */
    .knowledge-card {
      background: #f1f8e9;
      border-radius: 8px;
      padding: 18px 22px;
      margin-bottom: 28px;
      font-size: 13.5px;
    }
    .knowledge-card h3 {
      color: #33691e;
      font-size: 14px;
      margin-bottom: 12px;
      font-weight: 700;
    }
    .knowledge-card .warn {
      margin-top: 12px;
      padding: 8px 12px;
      background: #fff8e1;
      border-left: 3px solid #ffa000;
      border-radius: 4px;
      font-size: 13px;
      color: #5d4037;
    }

    /* 透视表四区域示意图 */
    .pivot-diagram {
      display: grid;
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto auto;
      gap: 8px;
      margin: 14px 0;
      max-width: 500px;
    }
    .pivot-zone {
      border-radius: 6px;
      padding: 12px 14px;
      font-size: 13px;
      text-align: center;
    }
    .pivot-zone .zone-name {
      font-weight: 700;
      font-size: 14px;
      margin-bottom: 4px;
    }
    .pivot-zone .zone-desc { font-size: 12px; opacity: .85; }
    .pz-filter  { background: #e3f2fd; border: 2px solid #90caf9; grid-column: 1 / -1; }
    .pz-filter  .zone-name { color: #0277bd; }
    .pz-rows    { background: #e8f5e9; border: 2px solid #a5d6a7; }
    .pz-rows    .zone-name { color: #2e7d32; }
    .pz-cols    { background: #fff3e0; border: 2px solid #ffcc80; }
    .pz-cols    .zone-name { color: #e65100; }
    .pz-values  { background: #fce4ec; border: 2px solid #f48fb1; grid-column: 1 / -1; }
    .pz-values  .zone-name { color: #880e4f; }

    /* ===== 难度块 ===== */
    .level-block {
      background: #fff;
      border-radius: 10px;
      box-shadow: 0 2px 10px rgba(0,0,0,.08);
      margin-bottom: 36px;
      overflow: hidden;
    }
    .level-header {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 18px 28px;
      color: #fff;
    }
    .level-header.basic  { background: linear-gradient(90deg,#43a047,#66bb6a); }
    .level-header.medium { background: linear-gradient(90deg,#fb8c00,#ffa726); }
    .level-header.hard   { background: linear-gradient(90deg,#e53935,#ef5350); }
    .level-badge {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 1px;
      background: rgba(255,255,255,.25);
      padding: 2px 10px;
      border-radius: 20px;
    }
    .level-header h2 { font-size: 18px; font-weight: 700; }
    .level-header .level-desc { font-size: 13px; opacity: .9; margin-left: auto; }

    .level-body { padding: 24px 28px; }

    /* ===== 下载区 ===== */
    .download-bar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 12px;
      background: #f1f8e9;
      border: 1px dashed #aed581;
      border-radius: 8px;
      padding: 14px 20px;
      margin-bottom: 24px;
    }
    .download-bar .dl-info { font-size: 13px; color: #444; }
    .download-bar .dl-info strong { color: #558b2f; }
    .btn-download {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: #558b2f;
      color: #fff;
      border: none;
      border-radius: 6px;
      padding: 8px 18px;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      transition: background .2s;
    }
    .btn-download:hover { background: #33691e; }
    .btn-download svg { width: 15px; height: 15px; fill: #fff; }

    /* ===== 透视表配置卡片 ===== */
    .pivot-config {
      background: #f8fff0;
      border: 2px solid #aed581;
      border-radius: 10px;
      padding: 18px 22px;
      margin: 16px 0;
    }
    .pivot-config .config-title {
      font-size: 15px;
      font-weight: 700;
      color: #33691e;
      margin-bottom: 14px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .config-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 10px;
    }
    .config-item {
      background: #fff;
      border-radius: 6px;
      padding: 10px 14px;
      border-left: 4px solid #558b2f;
      font-size: 13.5px;
    }
    .config-item .ci-zone {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 1px;
      color: #558b2f;
      margin-bottom: 4px;
    }
    .config-item .ci-field {
      font-weight: 700;
      color: #2c3e50;
      font-size: 14px;
    }
    .config-item .ci-note {
      font-size: 12px;
      color: #888;
      margin-top: 2px;
    }
    .config-item.rows  { border-left-color: #2e7d32; }
    .config-item.rows  .ci-zone { color: #2e7d32; }
    .config-item.cols  { border-left-color: #e65100; }
    .config-item.cols  .ci-zone { color: #e65100; }
    .config-item.vals  { border-left-color: #880e4f; }
    .config-item.vals  .ci-zone { color: #880e4f; }
    .config-item.filt  { border-left-color: #0277bd; }
    .config-item.filt  .ci-zone { color: #0277bd; }

    /* ===== 通用 ===== */
    .section-title {
      font-size: 15px;
      font-weight: 700;
      color: #2c3e50;
      border-left: 4px solid #558b2f;
      padding-left: 10px;
      margin: 22px 0 12px;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 13.5px;
      margin-bottom: 16px;
    }
    th {
      background: #f1f8e9;
      color: #33691e;
      font-weight: 700;
      padding: 9px 14px;
      text-align: left;
      border: 1px solid #c5e1a5;
    }
    td {
      padding: 8px 14px;
      border: 1px solid #e0e0e0;
      vertical-align: top;
    }
    tr:nth-child(even) td { background: #fafafa; }

    .task-list { padding-left: 0; list-style: none; counter-reset: task; }
    .task-list li {
      counter-increment: task;
      display: flex;
      gap: 12px;
      margin-bottom: 14px;
      font-size: 14px;
      align-items: flex-start;
    }
    .task-list li::before {
      content: counter(task);
      min-width: 26px;
      height: 26px;
      background: #558b2f;
      color: #fff;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 12px;
      font-weight: 700;
      flex-shrink: 0;
      margin-top: 1px;
    }
    .task-list.orange li::before { background: #fb8c00; }
    .task-list.red    li::before { background: #e53935; }

    .tip-box {
      border-radius: 8px;
      padding: 14px 18px;
      font-size: 13.5px;
      margin-top: 16px;
    }
    .tip-box.green  { background: #e8f5e9; border-left: 4px solid #43a047; }
    .tip-box.orange { background: #fff3e0; border-left: 4px solid #fb8c00; }
    .tip-box.red    { background: #fce4ec; border-left: 4px solid #e53935; }
    .tip-box.blue   { background: #e3f2fd; border-left: 4px solid #0277bd; }
    .tip-box .tip-title {
      font-weight: 700;
      margin-bottom: 8px;
      font-size: 13px;
    }
    .tip-box.green  .tip-title { color: #2e7d32; }
    .tip-box.orange .tip-title { color: #e65100; }
    .tip-box.red    .tip-title { color: #b71c1c; }
    .tip-box.blue   .tip-title { color: #01579b; }
    .tip-box ul { padding-left: 18px; }
    .tip-box ul li { margin-bottom: 5px; }

    .step-box {
      background: #f9fbe7;
      border: 1px solid #dce775;
      border-radius: 8px;
      padding: 14px 18px;
      margin: 14px 0;
      font-size: 13.5px;
    }
    .step-box .step-title {
      font-weight: 700;
      color: #827717;
      margin-bottom: 8px;
      font-size: 13px;
    }
    .step-box ol { padding-left: 20px; }
    .step-box ol li { margin-bottom: 6px; }

    /* 记录填写表 */
    .record-table th {
      background: #e8f5e9;
      color: #1b5e20;
      border-color: #a5d6a7;
    }
    .record-table.orange th {
      background: #fff3e0;
      color: #bf360c;
      border-color: #ffcc80;
    }
    .record-table.red th {
      background: #fce4ec;
      color: #880e4f;
      border-color: #f48fb1;
    }

    /* 透视表结果预览框 */
    .pivot-preview {
      background: #fff;
      border: 2px solid #c5e1a5;
      border-radius: 8px;
      padding: 16px;
      margin: 14px 0;
      overflow-x: auto;
    }
    .pivot-preview table th {
      background: #558b2f;
      color: #fff;
      border-color: #33691e;
    }
    .pivot-preview table th.col-header {
      background: #7cb342;
    }
    .pivot-preview table td {
      text-align: center;
    }
    .pivot-preview table td.row-label {
      font-weight: 700;
      background: #f1f8e9;
      text-align: left;
    }
    .pivot-preview table td.total {
      font-weight: 700;
      background: #dcedc8;
    }
    .pivot-preview .preview-title {
      font-size: 13px;
      font-weight: 700;
      color: #558b2f;
      margin-bottom: 10px;
    }

    /* 运营问题卡片 */
    .question-card {
      background: #fff8f0;
      border: 1px solid #ffcc80;
      border-radius: 8px;
      padding: 16px 20px;
      margin-bottom: 14px;
    }
    .question-card.red {
      background: #fff8f8;
      border-color: #ffcdd2;
    }
    .question-card .qc-title {
      font-weight: 700;
      color: #e65100;
      margin-bottom: 8px;
      font-size: 14px;
    }
    .question-card.red .qc-title { color: #c62828; }
    .question-card p { font-size: 13.5px; }

    /* 参考Sheet提示 */
    .ref-sheet-tip {
      background: #e8eaf6;
      border-left: 4px solid #3949ab;
      border-radius: 6px;
      padding: 12px 16px;
      font-size: 13px;
      margin: 14px 0;
      color: #283593;
    }
    .ref-sheet-tip strong { color: #1a237e; }

    code {
      background: #eceff1;
      border-radius: 3px;
      padding: 1px 6px;
      font-family: Consolas, monospace;
      font-size: 13px;
      color: #c62828;
    }
    .highlight {
      display: inline-block;
      background: #fff9c4;
      border-radius: 3px;
      padding: 0 5px;
      font-weight: 600;
    }

    footer {
      text-align: center;
      font-size: 12px;
      color: #999;
      margin-top: 48px;
      padding-top: 20px;
      border-top: 1px solid #eee;
    }
  </style>
</head>
<body>

<!-- ===== Banner ===== -->
<div class="banner">
  <div class="course-tag">数据分析基础 · 模块三 · 数据处理</div>
  <h1>3.2.4 数据透视表</h1>
  <div class="subtitle">快速多维度汇总数据，发现数据背后的规律与趋势</div>
  <div class="meta">
    <span>📁 配套文件：3.2.4_练习数据.xlsx</span>
    <span>🎯 三个难度等级</span>
    <span>🏢 情景：星途电商有限公司</span>
  </div>
</div>

<div class="container">

  <!-- 情景 -->
  <div class="scenario-card">
    <h2>📋 背景情景</h2>
    <p>
      星途电商有限公司每周运营例会上，主管都需要快速查看销售数据的多维度汇总结果，
      包括各类别、各渠道、各省份的销售表现对比。
      数据分析员小林发现，使用<strong>数据透视表</strong>可以在几分钟内完成过去需要几十个函数才能实现的汇总分析，
      还能随时切换分析维度。请跟随小林一起掌握这个强大工具。
    </p>
  </div>

  <!-- 知识点速览 -->
  <div class="knowledge-card">
    <h3>📖 知识点速览：数据透视表的四个区域</h3>
    <div class="pivot-diagram">
      <div class="pivot-zone pz-filter">
        <div class="zone-name">🔽 筛选器（Filter）</div>
        <div class="zone-desc">放在此区域的字段会出现在透视表上方，可以像筛选器一样过滤整张透视表的数据</div>
      </div>
      <div class="pivot-zone pz-rows">
        <div class="zone-name">📋 行（Rows）</div>
        <div class="zone-desc">该字段的每个值成为透视表的一行，通常放分类字段（如商品类别、省份）</div>
      </div>
      <div class="pivot-zone pz-cols">
        <div class="zone-name">📊 列（Columns）</div>
        <div class="zone-desc">该字段的每个值成为透视表的一列，用于交叉对比（如月份、渠道）</div>
      </div>
      <div class="pivot-zone pz-values">
        <div class="zone-name">🔢 值（Values）</div>
        <div class="zone-desc">放在此区域的字段会被汇总计算（求和、计数、平均值等），是透视表的核心数据</div>
      </div>
    </div>
    <div class="warn">
      ⚠️ 操作入口：选中数据区域任意单元格 → 【插入】选项卡 → 【数据透视表】→ 选择放置位置（建议新工作表）→ 确定。
      之后在右侧"字段列表"中，将字段拖入对应区域即可。
    </div>
  </div>

  <!-- 参考Sheet说明 -->
  <div class="ref-sheet-tip">
    📌 <strong>关于"参考透视表"Sheet：</strong>
    练习数据 Excel 文件（3.2.4_练习数据.xlsx）中已预置了一个"参考透视表"Sheet，
    包含每个难度对应的参考配置结果。
    建议<strong>先独立完成操作，再对照参考Sheet检验结果</strong>，不要提前查看。
  </div>

  <!-- ==================== 基础 ==================== -->
  <div class="level-block">
    <div class="level-header basic">
      <span class="level-badge">LEVEL 1</span>
      <h2>基础练习</h2>
      <span class="level-desc">适合：第一次操作透视表 · 25条数据 · 按指定配置创建</span>
    </div>
    <div class="level-body">

      <div class="download-bar">
        <div class="dl-info">
          📊 数据说明：<strong>25条订单数据</strong>｜5个字段｜按指定配置方案创建1张透视表
        </div>
        <button class="btn-download" onclick="downloadCSV('basic')">
          <svg viewBox="0 0 24 24"><path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"/></svg>
          下载 CSV 数据
        </button>
      </div>

      <div class="section-title">📌 数据字段说明</div>
      <table>
        <tr><th>字段名</th><th>类型</th><th>说明</th><th>示例值</th></tr>
        <tr><td>订单编号</td><td>文本</td><td>唯一订单号</td><td>ORD-2024-001</td></tr>
        <tr><td>商品类别</td><td>文本</td><td>商品大类，4种</td><td>充电宝 / 蓝牙耳机 / 手机壳 / 数据线</td></tr>
        <tr><td>销售省份</td><td>文本</td><td>买家所在省份，5个</td><td>广东 / 浙江 / 北京 / 上海 / 江苏</td></tr>
        <tr><td>销售额（元）</td><td>数值</td><td>成交金额</td><td>89.00</td></tr>
        <tr><td>销售数量（件）</td><td>数值</td><td>订单数量</td><td>2</td></tr>
      </table>

      <div class="section-title">✅ 任务要求</div>
      <ol class="task-list">
        <li>将 CSV 数据粘贴到 <code>3.2.4_练习数据.xlsx</code> 的"数据（基础）"Sheet 中，确保第一行为标题行。</li>
        <li>按照下方<span class="highlight">指定配置方案</span>，创建一张数据透视表，放置在新工作表中（命名为"透视表-基础"）。</li>
        <li>设置值区域的汇总方式为<span class="highlight">求和</span>，并将数值格式设置为<span class="highlight">保留2位小数</span>。</li>
        <li>将透视表结果填写到下方记录表中。</li>
        <li>与"参考透视表"Sheet 中的基础参考结果进行对照，记录是否一致。</li>
      </ol>

      <!-- 配置方案 -->
      <div class="section-title">🎯 指定配置方案</div>
      <div class="pivot-config">
        <div class="config-title">📊 透视表配置方案 A：各省份各类别销售额汇总</div>
        <div class="config-grid">
          <div class="config-item filt">
            <div class="ci-zone">🔽 筛选器</div>
            <div class="ci-field">（不设置）</div>
            <div class="ci-note">本题无需筛选器</div>
          </div>
          <div class="config-item rows">
            <div class="ci-zone">📋 行</div>
            <div class="ci-field">商品类别</div>
            <div class="ci-note">每种类别占一行</div>
          </div>
          <div class="config-item cols">
            <div class="ci-zone">📊 列</div>
            <div class="ci-field">销售省份</div>
            <div class="ci-note">每个省份占一列</div>
          </div>
          <div class="config-item vals">
            <div class="ci-zone">🔢 值</div>
            <div class="ci-field">销售额（元）— 求和</div>
            <div class="ci-note">汇总方式：求和</div>
          </div>
        </div>
      </div>

      <!-- 预期结构说明 -->
      <div class="section-title">📐 透视表预期结构（创建后应与此结构一致）</div>
      <div class="pivot-preview">
        <div class="preview-title">配置方案A 生成结果预览（数值由你完成后填入）</div>
        <table>
          <tr>
            <th>商品类别 \ 销售省份</th>
            <th class="col-header">北京</th>
            <th class="col-header">广东</th>
            <th class="col-header">江苏</th>
            <th class="col-header">上海</th>
            <th class="col-header">浙江</th>
            <th class="col-header">总计</th>
          </tr>
          <tr>
            <td class="row-label">充电宝</td>
            <td></td><td></td><td></td><td></td><td></td>
            <td class="total"></td>
          </tr>
          <tr>
            <td class="row-label">蓝牙耳机</td>
            <td></td><td></td><td></td><td></td><td></td>
            <td class="total"></td>
          </tr>
          <tr>
            <td class="row-label">手机壳</td>
            <td></td><td></td><td></td><td></td><td></td>
            <td class="total"></td>
          </tr>
          <tr>
            <td class="row-label">数据线</td>
            <td></td><td></td><td></td><td></td><td></td>
            <td class="total"></td>
          </tr>
          <tr>
            <td class="row-label total">总计</td>
            <td class="total"></td>
            <td class="total"></td>
            <td class="total"></td>
            <td class="total"></td>
            <td class="total"></td>
            <td class="total"></td>
